<?php

/**
 * @file
 * Essential tests for Innovation Hub module.
 * Simplified version for project presentation.
 */

class InnovationHubTest extends DrupalWebTestCase {

  protected $adminUser;
  protected $regularUser;
  protected $secondRegularUser;

  public static function getInfo() {
    return array(
      'name' => 'Innovation Hub Essential Tests',
      'description' => 'Core functionality tests for Innovation Hub module.',
      'group' => 'Innovation Hub',
    );
  }

  function setUp() {
    parent::setUp(
      'innovation_hub',
      'node',
      'comment',
      'field',
      'taxonomy',
      'field_ui'
    );

    // Ensure article content type exists
    if (!node_type_get_type('article')) {
      $this->drupalCreateContentType(array(
        'type' => 'article',
        'name' => 'Article'
      ));
    }

    // --------------------------------------------------
    // CREATE STATUS FIELD FOR TEST DATABASE
    // --------------------------------------------------

    if (!field_info_field('field_status')) {

      $field = array(
        'field_name' => 'field_status',
        'type' => 'text',
        'cardinality' => 1,
      );

      field_create_field($field);

      $instance = array(
        'field_name' => 'field_status',
        'entity_type' => 'node',
        'bundle' => 'article',
        'label' => 'Status',
        'widget' => array(
          'type' => 'text_textfield',
        ),
      );

      field_create_instance($instance);
    }

    // --------------------------------------------------
    // CREATE USERS
    // --------------------------------------------------

    $permissions = array(
      'access content',
      'create article content',
      'edit own article content',
      'post comments'
    );

    $this->regularUser = $this->drupalCreateUser($permissions);
    $this->secondRegularUser = $this->drupalCreateUser($permissions);

    $admin_permissions = array(
      'access content',
      'create article content',
      'edit any article content',
      'delete any article content',
      'administer nodes',
      'administer comments',
      'access administration pages'
    );

    $this->adminUser = $this->drupalCreateUser($admin_permissions);

    $this->drupalLogin($this->adminUser);
  }

  // =====================================================
  // 1. MODULE INSTALLATION
  // =====================================================

  function testModuleInstallation() {

    $this->assertTrue(
      module_exists('innovation_hub'),
      'Innovation Hub module is enabled.'
    );
  }

  // =====================================================
  // 2. DATABASE TABLE TEST
  // =====================================================

  function testDatabaseTables() {

    $this->assertTrue(
      db_table_exists('innovation_hub_votes'),
      'Votes table created successfully.'
    );
  }

  // =====================================================
  // 3. IDEA CREATION TEST
  // =====================================================

  function testIdeaCreation() {

    $edit = array(
      'title' => 'Test Innovation Idea',
      'body[und][0][value]' => 'This is a sample innovation idea.'
    );

    $this->drupalPost('node/add/article', $edit, t('Save'));

    $this->assertText('Test Innovation Idea');
  }

  // =====================================================
  // 4. IDEA EDIT TEST
  // =====================================================

  function testIdeaEdit() {

    $node = $this->drupalCreateNode(array(
      'title' => 'Original Idea',
      'type' => 'article'
    ));

    $this->drupalPost('node/' . $node->nid . '/edit', array(
      'title' => 'Updated Idea'
    ), t('Save'));

    $updated = node_load($node->nid, NULL, TRUE);

    $this->assertEqual(
      $updated->title,
      'Updated Idea',
      'Idea updated successfully.'
    );
  }

  // =====================================================
  // 5. IDEA STATUS WORKFLOW
  // =====================================================

  function testIdeaStatusWorkflow() {

    $node = $this->drupalCreateNode(array(
      'title' => 'Workflow Test Idea',
      'type' => 'article'
    ));

    $node->field_status[LANGUAGE_NONE][0]['value'] = 'Approved';

    node_save($node);

    $updated = node_load($node->nid, NULL, TRUE);

    $this->assertEqual(
      $updated->field_status[LANGUAGE_NONE][0]['value'],
      'Approved',
      'Idea approved successfully.'
    );
  }

  // =====================================================
  // 6. SECURITY TEST (XSS)
  // =====================================================

  function testXSSPrevention() {

    $node = $this->drupalCreateNode(array(
      'title' => 'Safe Idea',
      'type' => 'article'
    ));

    $this->drupalGet('node/' . $node->nid);

    $this->assertNoRaw('<script>', 'XSS script tags are blocked.');
  }

  // =====================================================
  // 7. ANONYMOUS ACCESS RESTRICTION
  // =====================================================

  function testAnonymousCannotCreateContent() {

    $this->drupalLogout();

    $this->drupalGet('node/add/article');

    $this->assertResponse(
      403,
      'Anonymous users cannot create ideas.'
    );
  }

  // =====================================================
  // 8. VOTING SYSTEM TEST
  // =====================================================

  function testVotingSystem() {

    $node = $this->drupalCreateNode(array(
      'title' => 'Voting Test Idea',
      'type' => 'article'
    ));

    $votes = db_query(
      "SELECT COUNT(*) FROM {innovation_hub_votes} WHERE nid = :nid",
      array(':nid' => $node->nid)
    )->fetchField();

    $this->assertEqual(
      $votes,
      0,
      'Initial vote count is zero.'
    );
  }

  // =====================================================
  // 9. MULTI USER TEST
  // =====================================================

  function testMultipleUsersCreateIdeas() {

    $this->drupalLogin($this->regularUser);

    $node1 = $this->drupalCreateNode(array(
      'title' => 'User1 Idea',
      'type' => 'article',
      'uid' => $this->regularUser->uid
    ));

    $this->drupalLogin($this->secondRegularUser);

    $node2 = $this->drupalCreateNode(array(
      'title' => 'User2 Idea',
      'type' => 'article',
      'uid' => $this->secondRegularUser->uid
    ));

    $this->assertTrue(
      $node1 && $node2,
      'Multiple users can create ideas.'
    );
  }

  // =====================================================
  // 10. ANALYTICS PAGE TEST
  // =====================================================

  function testAnalyticsDashboard() {

    $this->drupalGet('analytics');

    $this->assertNoText(
      'PDOException',
      'Analytics page loaded without database errors.'
    );
  }

}