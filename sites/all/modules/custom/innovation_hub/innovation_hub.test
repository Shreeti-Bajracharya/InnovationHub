<?php

class InnovationHubTest extends DrupalWebTestCase {

  public function getInfo() {
    return array(
      'name' => 'Innovation Hub Test',
      'description' => 'Tests idea submission',
      'group' => 'Innovation Hub'
    );
  }

  function testIdeaCreation() {

    $this->drupalCreateUser(array('create project_idea content'));

    $this->drupalLogin($user);

    $this->drupalPost('node/add/project-idea', array(
      'title' => 'Test Idea'
    ), 'Save');

    $this->assertText('Test Idea');
  }

}