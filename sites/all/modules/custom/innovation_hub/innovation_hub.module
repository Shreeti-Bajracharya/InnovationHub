<?php

/**
 * @file
 * Innovation Hub - Idea voting, trending algorithm, and analytics
 */

/**
 * Implements hook_menu()
 */
function innovation_hub_menu() {

  $items = array();

  $items['analytics'] = array(
    'title' => 'Innovation Hub Analytics',
    'page callback' => 'innovation_hub_analytics_page',
    'access arguments' => array('access content'),
    'file' => 'innovation_hub.pages.inc',
    'type' => MENU_NORMAL_ITEM,
  );

  $items['home'] = array(
    'title' => 'Innovation Hub',
    'page callback' => 'innovation_hub_homepage',
    'access arguments' => array('access content'),
    'file' => 'innovation_hub.pages.inc',
    'type' => MENU_NORMAL_ITEM,
  );

  // Vote route
  $items['idea/%/vote'] = array(
    'title' => 'Vote Idea',
    'page callback' => 'innovation_hub_vote',
    'page arguments' => array(1),
    'access callback' => 'user_is_logged_in',
    'access arguments' => array(),
    'type' => MENU_CALLBACK,
  );

  $items['admin/pending-events'] = array(
    'title' => 'Pending Events',
    'page callback' => 'innovation_hub_pending_events_page',
    'access arguments' => array('administer nodes'),
    'file' => 'innovation_hub.pages.inc',
  );

  $items['admin/events/approve/%'] = array(
    'page callback' => 'innovation_hub_event_approve',
    'page arguments' => array(3),
    'access arguments' => array('administer nodes'),
    'file' => 'innovation_hub.pages.inc',
  );

  $items['admin/events/reject/%'] = array(
    'page callback' => 'innovation_hub_event_reject',
    'page arguments' => array(3),
    'access arguments' => array('administer nodes'),
    'file' => 'innovation_hub.pages.inc',
  );

  return $items;
}

/**
 * Implements hook_menu() - Vote callback
 * Handles idea voting with security checks
 */
function innovation_hub_vote($nid) {
  global $user;

  $node = node_load($nid);
  if (!$node || $node->type != 'project_idea') {
    drupal_not_found();
  }

  // ✅ CHECK IF IDEA IS APPROVED (Security Check #1)
  if (!empty($node->field_status['und'][0]['value']) && 
      $node->field_status['und'][0]['value'] != 'Approved') {
    drupal_set_message('This idea has not been approved yet.', 'warning');
    drupal_access_denied();
  }

  // ✅ PREVENT SELF-VOTING (Security Check #2)
  if ($node->uid == $user->uid) {
    drupal_set_message('You cannot vote for your own idea.', 'warning');
    drupal_goto('node/'.$nid);
  }

  // ✅ PREVENT DUPLICATE VOTES (Security Check #3)
  $exists = db_query("
    SELECT 1
    FROM {innovation_hub_votes}
    WHERE uid = :uid AND nid = :nid
  ", array(':uid' => $user->uid, ':nid' => $nid))->fetchField();

  if ($exists) {
    drupal_set_message('You have already voted for this idea.', 'warning');
    drupal_goto('node/'.$nid);
  }

  // ✅ RECORD THE VOTE
  db_insert('innovation_hub_votes')
    ->fields(array(
      'uid' => $user->uid,
      'nid' => $nid,
      'created' => REQUEST_TIME,
    ))
    ->execute();

  // ✅ SYNC field_votes_value (For Views compatibility)
  $total_votes = db_query("
    SELECT COUNT(*) FROM {innovation_hub_votes} WHERE nid = :nid
  ", array(':nid' => $nid))->fetchField();

  $existing = db_query("
    SELECT entity_id
    FROM {field_data_field_votes}
    WHERE entity_id = :nid
    AND entity_type='node'
    AND bundle='project_idea'
    AND deleted=0
  ", array(':nid'=>$nid))->fetchField();

  if (!$existing) {
    // Insert new field row if it doesn't exist
    db_insert('field_data_field_votes')
      ->fields(array(
        'entity_type' => 'node',
        'bundle' => 'project_idea',
        'deleted' => 0,
        'entity_id' => $nid,
        'revision_id' => $nid,
        'language' => 'und',
        'delta' => 0,
        'field_votes_value' => $total_votes
      ))
      ->execute();
  } else {
    // Update main field table (USED BY VIEWS)
    db_update('field_data_field_votes')
      ->fields(array(
        'field_votes_value' => $total_votes
      ))
      ->condition('entity_id', $nid)
      ->condition('entity_type','node')
      ->condition('bundle','project_idea')
      ->execute();

    // Update revision table (USED BY NODE REVISIONS)
    db_update('field_revision_field_votes')
      ->fields(array(
        'field_votes_value' => $total_votes
      ))
      ->condition('entity_id', $nid)
      ->execute();
  }

  // ✅ UPDATE TRENDING SCORE
  innovation_hub_update_score($nid);

  watchdog('innovation_hub', 'User %uid voted for idea %nid', array('%uid' => $user->uid, '%nid' => $nid));

  drupal_set_message('Your vote has been recorded.');
  drupal_goto('node/' . $nid);
}

/**
 * Implements hook_block_info()
 * Defines the Trending Ideas block
 */
function innovation_hub_block_info() {
  $blocks['trending_ideas'] = array(
    'info' => t('Trending Ideas'),
    'cache' => DRUPAL_CACHE_GLOBAL,
  );
  return $blocks;
}

/**
 * Implements hook_block_view()
 * Renders the Trending Ideas block
 * ✅ ONLY SHOWS APPROVED IDEAS
 */
function innovation_hub_block_view($delta = '') {
  $block = array();

  if ($delta == 'trending_ideas') {

    // ✅ FIXED QUERY - ONLY APPROVED IDEAS
    $result = db_query("
      SELECT n.nid, n.title,
             v.field_votes_value,
             s.field_trending_score_value,
             t.name AS difficulty
      FROM {node} n
      LEFT JOIN {field_data_field_votes} v
        ON n.nid = v.entity_id
      LEFT JOIN {field_data_field_trending_score} s
        ON n.nid = s.entity_id
      LEFT JOIN {field_data_field_difficulty} d
        ON n.nid = d.entity_id
      LEFT JOIN {taxonomy_term_data} t
        ON d.field_difficulty_tid = t.tid
      LEFT JOIN {field_data_field_status} fs
        ON n.nid = fs.entity_id
      WHERE n.type='project_idea'
      AND n.status = 1
      AND fs.field_status_value = 'Approved'
      ORDER BY s.field_trending_score_value DESC
      LIMIT 5
    ");

    $items = array();

    foreach ($result as $row) {
      $votes = $row->field_votes_value ? $row->field_votes_value : 0;
      $score = $row->field_trending_score_value ? $row->field_trending_score_value : 0;

      $items[] = '
        <div class="idea-card">
          <a href="'.url('node/'.$row->nid).'">'.check_plain($row->title).'</a>
          <div class="idea-stats">
            <span class="votes">👍 '.$votes.' Votes</span>
            <span class="score">🔥 '.$score.' Score</span>
          </div>
        </div>
      ';
    }

    if (empty($items)) {
      $items[] = '<p>No trending ideas yet.</p>';
    }

    $block['subject'] = t('Trending Ideas');
    $block['content'] = array('#markup' => implode('', $items));
  }

  return $block;
}

/**
 * Implements hook_node_insert()
 * Actions when idea or event is created
 */
function innovation_hub_node_insert($node) {

  if ($node->type == 'project_idea') {
    // Set default status to Pending for new ideas
    db_update('field_data_field_status')
      ->fields(array('field_status_value' => 'Pending'))
      ->condition('entity_id', $node->nid)
      ->execute();

    watchdog('innovation_hub', 'New idea submitted: %title (Status: Pending)', array('%title' => $node->title));
    innovation_hub_update_score($node->nid);
  }

  if ($node->type == 'hackathon_event') {
    // Set default status to Pending for new events
    db_update('field_data_field_event_status')
      ->fields(array('field_event_status_value' => 'pending'))
      ->condition('entity_id', $node->nid)
      ->execute();

    watchdog('innovation_hub', 'New event submitted and set to pending: %title', array('%title' => $node->title));
  }
}

/**
 * Implements hook_node_view()
 * Adds vote button to idea page
 */
function innovation_hub_node_view($node, $view_mode, $langcode) {

  if ($node->type == 'project_idea') {
    // Check if idea is approved before showing vote button
    $is_approved = FALSE;
    if (!empty($node->field_status['und'][0]['value']) && 
        $node->field_status['und'][0]['value'] == 'Approved') {
      $is_approved = TRUE;
    }

    if ($is_approved) {
      $vote_link = l(
        '👍 Vote',
        'idea/'.$node->nid.'/vote',
        array('attributes' => array('class' => array('btn','btn-success','btn-sm')))
      );

      $node->content['vote_button'] = array(
        '#markup' => '<div class="idea-vote">'.$vote_link.'</div>',
        '#weight' => 10,
      );
    }
  }
}

/**
 * Calculates trending score for an idea
 * Formula: (votes × 2) + comments + recency_bonus
 */
function innovation_hub_calculate_score($nid) {

  $created = db_query("
    SELECT created FROM {node} WHERE nid = :nid
  ", array(':nid'=>$nid))->fetchField();
  
  if (!$created) {
    return 0;
  }

  // Votes from field_votes_value (matches Ideas page)
  $votes = db_query("
    SELECT field_votes_value 
    FROM {field_data_field_votes} 
    WHERE entity_id = :nid
  ", array(':nid'=>$nid))->fetchField();
  $votes = $votes ? $votes : 0;

  // Comments
  $comments = db_query("
    SELECT COUNT(*) FROM {comment} WHERE nid = :nid
  ", array(':nid'=>$nid))->fetchField();
  $comments = $comments ? $comments : 0;

  // Recency bonus (in days since creation)
  $days_old = (REQUEST_TIME - $created) / 86400;
  if ($days_old <= 3) {
    $recency_bonus = 3;
  } elseif ($days_old <= 7) {
    $recency_bonus = 1;
  } else {
    $recency_bonus = 0;
  }

  // Final score formula
  $score = ($votes * 2) + $comments + $recency_bonus;

  return $score;
}

/**
 * Updates trending score (insert if missing, update if exists)
 */
function innovation_hub_update_score($nid) {

  $score = innovation_hub_calculate_score($nid);

  $existing = db_query("
    SELECT field_trending_score_value
    FROM {field_data_field_trending_score}
    WHERE entity_id = :nid
  ", array(':nid'=>$nid))->fetchField();

  if ($existing === FALSE) {
    // Insert new trending score row
    db_insert('field_data_field_trending_score')
      ->fields(array(
        'entity_type' => 'node',
        'bundle' => 'project_idea',
        'deleted' => 0,
        'entity_id' => $nid,
        'revision_id' => $nid,
        'language' => 'und',
        'delta' => 0,
        'field_trending_score_value' => $score
      ))
      ->execute();
  } else {
    // Update existing trending score
    db_update('field_data_field_trending_score')
      ->fields(array('field_trending_score_value' => $score))
      ->condition('entity_id', $nid)
      ->execute();

    // Also update revision table
    db_update('field_revision_field_trending_score')
      ->fields(array('field_trending_score_value' => $score))
      ->condition('entity_id', $nid)
      ->execute();
  }
}

/**
 * Implements hook_node_update()
 * Updates score when idea is edited
 */
function innovation_hub_node_update($node) {
  if ($node->type == 'project_idea') {
    innovation_hub_update_score($node->nid);
  }
}

/**
 * Implements hook_comment_insert()
 * Updates score when comment is added
 */
function innovation_hub_comment_insert($comment) {
  innovation_hub_update_score($comment->nid);
}

/**
 * Implements hook_form_alter()
 * Improves Idea Submission Form
 */
function innovation_hub_form_alter(&$form, &$form_state, $form_id) {

  // Modify Project Idea submission form
  if ($form_id == 'project_idea_node_form') {

    // Add helpful description to title
    $form['title']['#description'] = t('Enter a clear and innovative project idea title.');

    // Add placeholder text
    if (!isset($form['title']['#attributes'])) {
      $form['title']['#attributes'] = array();
    }
    $form['title']['#attributes']['placeholder'] = t('Example: AI Powered Disaster Prediction System');

    // Improve description field (body)
    if (isset($form['body'])) {
      $form['body'][LANGUAGE_NONE][0]['#description'] = t('Describe your idea, its impact, and technologies involved.');
    }

    // Add helpful message about approval
    if (isset($form['status'])) {
      $form['status']['widget']['#description'] = t('Your idea will be pending approval by an administrator before appearing publicly.');
    }
  }
}

/**
 * Implements hook_theme()
 * Registers custom theme hooks and templates
 */
function innovation_hub_theme() {
  return array(
    'innovation_hub_homepage' => array(
      'template' => 'innovation-hub-homepage',
      'variables' => array(
        'ideas' => NULL,
        'events' => NULL,
        'stats' => NULL,
      ),
    ),
  );
}

/**
 * Implements hook_views_query_alter()
 * Modifies Views queries for Ideas view
 */
function innovation_hub_views_query_alter(&$view, &$query) {
  
  // Modify the Ideas view to sort by trending score
  if ($view->name == 'ideas') {
    // Clear existing sort criteria
    $query->orderby = array();

    // Sort by trending score (descending - highest first)
    $query->orderby[] = array(
      'field' => 'field_trending_score_value', 
      'direction' => 'DESC',
    );
  }
}

/**
 * Implements hook_simpletest_alter().
 */
function innovation_hub_simpletest_alter(&$tests) {
  // Get module path
  $module_path = drupal_get_path('module', 'innovation_hub');
  $test_file = $module_path . '/innovation_hub.test';
  
  // Only proceed if test file exists
  if (!file_exists($test_file)) {
    return;
  }
  
  // Include the test file
  require_once $test_file;
  
  // Register each test class
  if (class_exists('InnovationHubTest')) {
    $tests['InnovationHubTest'] = $test_file;
  }
}
?>